# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so

# Virtual environments
.venv/
venv/
env/

# Jupyter
.ipynb_checkpoints/

# Build / packaging
build/
dist/
*.egg-info/

# IDE / editor
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db

# Logs
*.log

# Cache / test
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/

# Weights cache
weights/*
!weights/.gitkeep

# Data: keep folder structure only
data/raw/*
!data/raw/.gitkeep

data/processed/*
!data/processed/.gitkeep

data/sample/*
!data/sample/.gitkeep

# Checkpoints: keep folder only
checkpoints/*
!checkpoints/.gitkeep

# Outputs: keep folder structure only
outputs/*
!outputs/.gitkeep

outputs/logs/*
!outputs/logs/.gitkeep

outputs/figures/*
!outputs/figures/.gitkeep

outputs/examples/*
!outputs/examples/.gitkeep

# Allow a few showcase files if you want
!outputs/examples/*.png
!outputs/examples/*.jpg
!outputs/examples/*.jpeg
!outputs/examples/*.gif
!outputs/examples/*.json

!outputs/figures/*.png
!outputs/figures/*.jpg
!outputs/figures/*.jpeg